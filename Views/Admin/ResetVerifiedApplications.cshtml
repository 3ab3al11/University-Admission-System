@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["ResetVerifiedTitle"].Value;
    int profiles = ViewBag.LinkedProfiles ?? 0;
    int prefs = ViewBag.LinkedPreferences ?? 0;
    int allocs = ViewBag.LinkedAllocations ?? 0;
}

<div class="mb-4">
    <h2 class="fw-bold text-danger">
        <i class="bi bi-arrow-counterclockwise ms-2"></i>
        @L["ResetVerifiedTitle"]
    </h2>
    <p class="text-muted">@L["ResetVerifiedSub"]</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card card-university mb-4">
            <div class="card-body">
                <h5 class="fw-bold mb-3">@L["ResetWillDo"]</h5>
                <ul class="mb-0">
                    <li class="mb-2">@L["ResetItem1", profiles]</li>
                    <li class="mb-2">@L["ResetItem2"]</li>
                    <li class="mb-2">@L["ResetItem3", prefs, allocs]</li>
                    <li class="mb-2">@L["ResetItem4"]</li>
                </ul>
            </div>
        </div>

        <div class="alert alert-success">
            <i class="bi bi-shield-check ms-2"></i>
            @L["ResetSafeNote"]
        </div>

        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle-fill ms-2"></i>
            @L["ResetIrreversible"]
        </div>

        @if (profiles == 0)
        {
            <div class="alert alert-info">@L["NoLinkedStudents"]</div>
            <a asp-action="DeleteOfficialRecords" class="btn btn-outline-secondary">@L["BackShort"]</a>
        }
        else
        {
            <form asp-action="ResetVerifiedApplicationsConfirmed" method="post"
                  onsubmit="return confirm(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(string.Format(L["ConfirmResetJs"].Value, profiles))));">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-lg">
                    <i class="bi bi-arrow-counterclockwise ms-2"></i>
                    @L["ConfirmResetBtn"]
                </button>
                <a asp-action="DeleteOfficialRecords" class="btn btn-outline-secondary btn-lg">@L["Cancel"]</a>
            </form>
        }
    </div>
</div>
