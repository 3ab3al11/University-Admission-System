@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ErrorViewModel
@{
    ViewData["Title"] = L["UnexpectedErrorTitle"].Value;
}

<div class="row justify-content-center py-5">
    <div class="col-lg-7">
        <div class="alert alert-danger p-4" role="alert">
            <h1 class="h3 fw-bold">@L["UnexpectedErrorTitle"]</h1>
            <p class="mb-0">@L["UnexpectedErrorBody"]</p>
        </div>

        @if (Model.ShowRequestId)
        {
            <p class="text-muted">
                <strong>@L["RequestIdLabel"]:</strong>
                <code dir="ltr">@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-gold">
            @L["GoHome"]
        </a>
    </div>
</div>
