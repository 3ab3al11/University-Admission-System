@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["HomePageTitle"].Value;
}

<!-- Hero Section -->
<section class="hero-section py-5 mb-5">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8 mx-auto text-center">
                <h1 class="display-4 fw-bold mb-4" style="color: var(--black-text);">
                    @L["HomeHeroTitle"]
                </h1>
                <p class="lead mb-4" style="color: var(--muted-text); font-size: 1.2rem;">
                    @L["HomeHeroSubtitle"]
                </p>
                <a href="/Account/Register" class="btn btn-primary-gold btn-lg px-5 py-3">
                    <i class="bi bi-arrow-left-circle ms-2"></i>
                    @L["StartApplicationNow"]
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features-section py-5">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card card-university text-center p-4 h-100">
                    <div class="mb-3">
                        <i class="bi bi-award-fill text-gold" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">@L["FeatureAccredTitle"]</h4>
                    <p class="text-muted">@L["FeatureAccredSub"]</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-university text-center p-4 h-100">
                    <div class="mb-3">
                        <i class="bi bi-people-fill text-gold" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">@L["FeatureFacultyTitle"]</h4>
                    <p class="text-muted">@L["FeatureFacultySub"]</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card card-university text-center p-4 h-100">
                    <div class="mb-3">
                        <i class="bi bi-book-fill text-gold" style="font-size: 3rem;"></i>
                    </div>
                    <h4 class="fw-bold mb-3">@L["FeatureProgramsTitle"]</h4>
                    <p class="text-muted">@L["FeatureProgramsSub"]</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Colleges Section -->
<section class="colleges-section py-5 my-5">
    <div class="container">
        <h2 class="section-title text-center mb-5">@L["AvailableColleges"]</h2>
        <div class="row g-4">
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-gear-fill text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeEng"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-capsule text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegePharm"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-heart-pulse-fill text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeDent"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-hospital-fill text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeMed"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-translate text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeLang"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-graph-up-arrow text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeFinAdmin"]</h5>
                </div>
            </div>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card card-university text-center p-4 h-100">
                    <i class="bi bi-cpu-fill text-gold mb-3" style="font-size: 2.5rem;"></i>
                    <h5 class="fw-bold">@L["CollegeCompAI"]</h5>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section py-5 my-5">
    <div class="container">
        <div class="card" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); border: none; border-radius: 16px;">
            <div class="card-body p-5 text-center text-white">
                <h2 class="fw-bold mb-3">@L["CtaReady"]</h2>
                <p class="lead mb-4">@L["CtaSubtitle"]</p>
                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="/Account/Login" class="btn btn-light btn-lg px-5" style="font-weight: 600;">
                        @L["Login"]
                    </a>
                    <a href="/Account/Register" class="btn btn-outline-light btn-lg px-5" style="font-weight: 600;">
                        @L["Register"]
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
