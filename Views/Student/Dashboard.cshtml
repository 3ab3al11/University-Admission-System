@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.StudentDashboardViewModel
@{
    ViewData["Title"] = L["Dashboard"].Value;
    bool admissionsOpen = ViewBag.AdmissionsOpen as bool? ?? true;
    var gate = ViewBag.GateStatus as ANU_Admissions.Services.AdmissionsGateStatus;
}

<!-- Welcome Header -->
<div class="mb-4">
    <h2 class="fw-bold" style="color: var(--black-text);">@L["WelcomeDashboard"]</h2>
    <p class="text-muted">@L["WelcomeDashboardSub"]</p>
</div>

<partial name="_StudentAlerts" />

@{
    // State-aware banner. Defaults to the original "closed by admin" copy when
    // GateStatus isn't supplied (defensive — the controller always sets it now).
    string bannerClass = "alert-danger";
    string bannerIcon = "bi-lock-fill";
    string bannerTitle = L["AdmissionsClosed"].Value;
    string bannerBody = L["AdmissionsClosedSub"].Value;
    bool showBanner = !admissionsOpen;
    if (gate != null)
    {
        switch (gate.State)
        {
            case ANU_Admissions.Services.AdmissionsGateState.ManualClosed:
                bannerTitle = L["AdmissionsClosedManually"].Value;
                bannerBody  = L["AdmissionsClosedSub"].Value;
                break;
            case ANU_Admissions.Services.AdmissionsGateState.NotStarted:
                bannerClass = "alert-warning"; bannerIcon = "bi-hourglass-split";
                bannerTitle = L["AdmissionsNotStarted"].Value;
                bannerBody  = gate.StartAt.HasValue
                    ? $"{L["AdmissionsStartsAt"].Value}: {gate.StartAt.Value:yyyy-MM-dd HH:mm}" : "";
                break;
            case ANU_Admissions.Services.AdmissionsGateState.Expired:
                bannerClass = "alert-secondary"; bannerIcon = "bi-calendar-x-fill";
                bannerTitle = L["AdmissionsExpired"].Value;
                bannerBody  = "";
                break;
            case ANU_Admissions.Services.AdmissionsGateState.Open:
                bannerClass = "alert-success"; bannerIcon = "bi-unlock-fill";
                bannerTitle = L["AdmissionsOpenNow"].Value;
                bannerBody  = gate.EndAt.HasValue
                    ? $"{L["AdmissionsEndsAt"].Value}: {gate.EndAt.Value:yyyy-MM-dd HH:mm}" : "";
                showBanner = true; // info banner — visible while open with schedule
                break;
        }
    }
}

@if (showBanner)
{
    <div class="alert @bannerClass d-flex align-items-start mb-4" role="alert">
        <i class="bi @bannerIcon ms-2 mt-1" style="font-size: 1.4rem;"></i>
        <div>
            <h6 class="fw-bold mb-1">@bannerTitle</h6>
            @if (!string.IsNullOrEmpty(bannerBody))
            {
                <small class="d-block">@bannerBody</small>
            }
        </div>
    </div>
}

<div class="row g-4">
    <!-- Application Status Card (Dynamic) -->
    <div class="col-lg-6">
        <div class="card card-university h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-file-earmark-text text-gold ms-2"></i>
                        @L["ApplicationStatus"]
                    </h5>
                    @if (!admissionsOpen)
                    {
                        <span class="badge bg-secondary badge-status">@L["AdmissionsClosedBadge"]</span>
                    }
                    else
                    {
                        <span class="badge @Model.GetStatusBadgeClass() badge-status">@Model.GetStatusText()</span>
                    }
                </div>
                @if (!admissionsOpen)
                {
                    <p class="text-muted mb-3">@L["ClosedFromAdminShort"]</p>
                    <button type="button" class="btn btn-secondary" disabled>
                        <i class="bi bi-lock ms-2"></i>
                        @L["UnavailableNow"]
                    </button>
                }
                else
                {
                    <p class="text-muted mb-3">@Model.GetStatusText()</p>
                    <a href="@Model.GetNextActionUrl()" class="btn btn-primary-gold">
                        <i class="bi bi-arrow-left-circle ms-2"></i>
                        @Model.GetNextActionText()
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Basic Info Card - With Data -->
    <div class="col-lg-6">
        <div class="card card-university h-100">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">
                    <i class="bi bi-person-fill text-gold ms-2"></i>
                    @L["BasicInfo"]
                </h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["FullName"]</small>
                            <strong>@Model.DisplayName</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["Email"]</small>
                            <strong>@Model.Email</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["StudentPhone"]</small>
                            <strong>@Model.PhoneNumber</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["ParentPhone"]</small>
                            <strong>@Model.ParentPhoneNumber</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["Section"]</small>
                            <strong>@Model.Section</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-2">
                            <small class="text-muted d-block">@L["EquivalentPercentage"]</small>
                            <strong class="text-gold">@Model.EquivalentPercentage%</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Cards in 2x2 Grid -->
    <div class="col-12">
        <div class="row g-3 mb-4">
            @* Preferences card — hidden once the student is allocated (item 5) *@
            @if (!Model.HasAllocation)
            {
                <div class="col-md-3 col-sm-6">
                    <div class="card h-100" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); border: none; @(admissionsOpen ? "" : "opacity:0.55;")">
                        <div class="card-body p-3 text-center text-white">
                            <i class="bi @(admissionsOpen ? "bi-list-check" : "bi-lock-fill")" style="font-size: 2rem; margin-bottom: 0.5rem;"></i>
                            <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">@L["PreferencesCard"]</h6>
                            @if (admissionsOpen)
                            {
                                <p class="small mb-2" style="font-size: 0.75rem;">@L["PreferencesCardSub"]</p>
                                <a href="/Student/Preferences" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;">
                                    <i class="bi bi-arrow-left-circle ms-1"></i>
                                    @L["StartSelection"]
                                </a>
                            }
                            else
                            {
                                <p class="small mb-2" style="font-size: 0.75rem;">@L["PreferencesUnavailable"]</p>
                                <button type="button" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;" disabled>
                                    <i class="bi bi-lock ms-1"></i>
                                    @L["ClosedByAdmin"]
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Edit Data Card -->
            <div class="col-md-3 col-sm-6">
                <div class="card h-100" style="background: linear-gradient(135deg, var(--primary-gold) 0%, var(--hover-gold) 100%); border: none; @(admissionsOpen ? "" : "opacity:0.55;")">
                    <div class="card-body p-3 text-center text-white">
                        <i class="bi @(admissionsOpen ? "bi-pencil-square" : "bi-lock-fill")" style="font-size: 2rem; margin-bottom: 0.5rem;"></i>
                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">@L["EditDataCard"]</h6>
                        @if (admissionsOpen)
                        {
                            <p class="small mb-2" style="font-size: 0.75rem;">@L["EditDataCardSub"]</p>
                            <a href="/Student/ApplicationForm" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;">
                                <i class="bi bi-pencil ms-1"></i>
                                @L["EditAction"]
                            </a>
                        }
                        else
                        {
                            <p class="small mb-2" style="font-size: 0.75rem;">@L["EditUnavailable"]</p>
                            <button type="button" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;" disabled>
                                <i class="bi bi-lock ms-1"></i>
                                @L["ClosedByAdmin"]
                            </button>
                        }
                    </div>
                </div>
            </div>

            <!-- Allocation Status Card -->
            <div class="col-md-3 col-sm-6">
                <div class="card h-100" style="background: linear-gradient(135deg, #059669 0%, #10b981 100%); border: none;">
                    <div class="card-body p-3 text-center text-white">
                        <i class="bi bi-trophy" style="font-size: 2rem; margin-bottom: 0.5rem;"></i>
                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">@L["AllocationCard"]</h6>
                        <p class="small mb-2" style="font-size: 0.75rem;">@L["AllocationCardSub"]</p>
                        <a href="/Student/AllocationStatus" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;">
                            <i class="bi bi-search ms-1"></i>
                            @L["ShowStatus"]
                        </a>
                    </div>
                </div>
            </div>

            <!-- Attendance Instructions Card (replaces online document upload) -->
            <div class="col-md-3 col-sm-6">
                <div class="card h-100" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%); border: none;">
                    <div class="card-body p-3 text-center text-white">
                        <i class="bi bi-card-checklist" style="font-size: 2rem; margin-bottom: 0.5rem;"></i>
                        <h6 class="fw-bold mb-1" style="font-size: 0.9rem;">@L["AttendanceCard"]</h6>
                        <p class="small mb-2" style="font-size: 0.75rem;">@L["AttendanceCardSub"]</p>
                        <a href="/Student/AllocationResult" class="btn btn-light btn-sm fw-bold w-100" style="font-size: 0.8rem;">
                            <i class="bi bi-arrow-left-circle ms-1"></i>
                            @L["ShowInstructions"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Notifications Card -->
    <div class="col-12">
        <div class="card card-university">
            <div class="card-body p-3">
                <h6 class="fw-bold mb-3" style="font-size: 0.95rem;">
                    <i class="bi bi-bell-fill text-gold ms-2"></i>
                    @L["NotificationsHeader"]
                </h6>

                <!-- Blue Info Notification -->
                <div class="alert alert-info d-flex align-items-start mb-2 py-2" role="alert" style="font-size: 0.85rem;">
                    <i class="bi bi-info-circle-fill ms-2 mt-1" style="font-size: 1rem;"></i>
                    <div>@Html.Raw(L["NotifAdmissionOpen"].Value)</div>
                </div>

                <!-- Yellow Warning Notification -->
                <div class="alert alert-warning d-flex align-items-start mb-2 py-2" role="alert" style="font-size: 0.85rem;">
                    <i class="bi bi-exclamation-triangle-fill ms-2 mt-1" style="font-size: 1rem;"></i>
                    <div>@Html.Raw(L["NotifDeadline"].Value)</div>
                </div>

                <!-- Preferences Reminder -->
                <div class="alert alert-primary d-flex align-items-start mb-0 py-2" role="alert" style="font-size: 0.85rem;">
                    <i class="bi bi-bookmark-star-fill ms-2 mt-1" style="font-size: 1rem;"></i>
                    <div>@Html.Raw(L["NotifPrefsReminder"].Value)</div>
                </div>
            </div>
        </div>
    </div>
</div>
