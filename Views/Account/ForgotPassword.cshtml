@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = L["ForgotPasswordTitle"].Value;
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="card card-university">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold" style="color: var(--black-text);">
                        <i class="bi bi-key text-gold ms-2"></i>
                        @L["ForgotPasswordTitle"]
                    </h3>
                    <p class="text-muted">@L["ForgotPasswordSub"]</p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold">@L["Email"]</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-envelope text-gold"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-gold btn-lg">
                            <i class="bi bi-send ms-2"></i>
                            @L["SendResetLink"]
                        </button>
                        <a asp-action="Login" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-right ms-2"></i>
                            @L["BackToLogin"]
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
