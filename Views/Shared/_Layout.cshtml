@using System.Globalization
@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@{
    var culture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "en" : "ar";
    var isRtl = culture == "ar";
    var bootstrapHref = isRtl
        ? "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.rtl.min.css"
        : "https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@culture" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @L["SiteTitle"]</title>

    @* Initialize theme BEFORE any CSS to avoid flash-of-light. *@
    <script>
        (function () {
            try {
                var saved = localStorage.getItem('anu-theme');
                var prefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
                var theme = saved || (prefersDark ? 'dark' : 'light');
                document.documentElement.setAttribute('data-bs-theme', theme);
            } catch (e) { /* localStorage blocked — fall back to light */ }
        })();
    </script>

    <link rel="stylesheet" href="@bootstrapHref">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg shadow-sm">
            <div class="container-fluid px-4">
                <!-- Brand Section -->
                <div class="d-flex align-items-center gap-3">
                    <img src="~/images/logo.png" alt="University Logo" height="60">
                    <div>
                        <div class="navbar-brand mb-0 fw-bold" style="font-size: 1.1rem;">@L["UniversityName"]</div>
                        <div class="text-muted" style="font-size: 0.85rem; margin-top: -5px;">@L["SiteTitle"]</div>
                    </div>
                </div>

                <!-- Toggler for mobile -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Navigation Buttons -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <div class="ms-auto navbar-actions d-flex align-items-center flex-wrap">

                        <!-- Theme toggle -->
                        <button type="button" class="theme-toggle" id="themeToggle"
                                title="@L["ThemeLight"] / @L["ThemeDark"]">
                            <i class="bi bi-moon-stars-fill"></i>
                            <i class="bi bi-sun-fill"></i>
                        </button>

                        <!-- Language switcher -->
                        <div class="dropdown">
                            <button class="lang-toggle dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-translate"></i>
                                <span class="ms-1">@(culture == "ar" ? L["Arabic"] : L["English"])</span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item @(culture == "ar" ? "active" : "")"
                                       href="/Language/Set?culture=ar&returnUrl=@Uri.EscapeDataString(returnUrl)">@L["Arabic"]</a></li>
                                <li><a class="dropdown-item @(culture == "en" ? "active" : "")"
                                       href="/Language/Set?culture=en&returnUrl=@Uri.EscapeDataString(returnUrl)">@L["English"]</a></li>
                            </ul>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <!-- Dashboard (subtle gold link, not a heavy button) -->
                            var dashUrl = User.IsInRole("Admin") ? "/Admin/Dashboard" : "/Student/Dashboard";
                            <a href="@dashUrl" class="navbar-link-gold" title="@L["Dashboard"]">
                                <i class="bi bi-house-door"></i>
                                <span class="d-none d-md-inline">@L["Dashboard"]</span>
                            </a>

                            <!-- User dropdown: trigger shows icon + email + caret.
                                 Menu shows "Signed in as ..." then a logout button
                                 wrapped in a POST form so the AntiForgeryToken is
                                 still emitted by the ASP.NET tag-helper. -->
                            <div class="dropdown">
                                <button class="navbar-user-toggle dropdown-toggle" type="button"
                                        data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle"></i>
                                    <span class="navbar-user-name d-none d-md-inline">@User.Identity.Name</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li class="px-3 py-2">
                                        <div class="small text-muted">@L["SignedInAs"]</div>
                                        <div class="navbar-user-email">@User.Identity.Name</div>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item navbar-logout-item">
                                                <i class="bi bi-box-arrow-left"></i>
                                                <span>@L["Logout"]</span>
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            @* Sign in is a neutral-outline button (same size as
                               Create account) so the row looks balanced. Different
                               colour family from gold so the two don't read as a
                               single block. *@
                            <a href="/Account/Login" class="btn btn-outline-secondary">
                                <i class="bi bi-box-arrow-in-right ms-2"></i>
                                @L["Login"]
                            </a>
                            <a href="/Account/Register" class="btn btn-primary-gold">
                                <i class="bi bi-person-plus ms-2"></i>
                                @L["Register"]
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container my-4">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-5">
        <div class="container text-center py-3">
            &copy; 2026 - @L["UniversityName"] - @L["FooterRights"]
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        // Theme toggle: flips data-bs-theme and persists to localStorage.
        (function () {
            var btn = document.getElementById('themeToggle');
            if (!btn) return;
            btn.addEventListener('click', function () {
                var current = document.documentElement.getAttribute('data-bs-theme') || 'light';
                var next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-bs-theme', next);
                try { localStorage.setItem('anu-theme', next); } catch (e) { }
            });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
