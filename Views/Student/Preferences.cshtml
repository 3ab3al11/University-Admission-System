@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@using ANU_Admissions.Helpers
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.PreferencesViewModel
@{
    ViewData["Title"] = L["PreferencesTitle"].Value;
    bool admissionsOpen = ViewBag.AdmissionsOpen as bool? ?? true;
    var gate = ViewBag.GateStatus as ANU_Admissions.Services.AdmissionsGateStatus;
}

@if (!admissionsOpen)
{
    // Same state-machine the dashboard uses, so the wording is consistent
    // whichever page the student lands on.
    string title = L["PreferencesClosedTitle"].Value;
    string body  = L["PreferencesClosedBody"].Value;
    string css   = "alert-danger"; string icon = "bi-lock-fill";
    if (gate != null)
    {
        switch (gate.State)
        {
            case ANU_Admissions.Services.AdmissionsGateState.ManualClosed:
                title = L["AdmissionsClosedManually"].Value; break;
            case ANU_Admissions.Services.AdmissionsGateState.NotStarted:
                css = "alert-warning"; icon = "bi-hourglass-split";
                title = L["AdmissionsNotStarted"].Value;
                body = gate.StartAt.HasValue
                    ? $"{L["AdmissionsStartsAt"].Value}: {gate.StartAt.Value:yyyy-MM-dd HH:mm}" : body;
                break;
            case ANU_Admissions.Services.AdmissionsGateState.Expired:
                css = "alert-secondary"; icon = "bi-calendar-x-fill";
                title = L["AdmissionsExpired"].Value;
                body = "";
                break;
        }
    }
    <div class="mb-4">
        <h2 class="fw-bold" style="color: var(--black-text);">@L["PreferencesTitle"]</h2>
    </div>
    <div class="alert @css d-flex align-items-start" role="alert">
        <i class="bi @icon ms-2 mt-1" style="font-size: 1.6rem;"></i>
        <div>
            <h5 class="fw-bold mb-1">@title</h5>
            @if (!string.IsNullOrEmpty(body))
            {
                <p class="mb-0">@body</p>
            }
        </div>
    </div>
    <a href="/Student/Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-right ms-2"></i> @L["BackToDashboard"]
    </a>
    return;
}

@if (Model == null)
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle ms-2"></i>
        @L["LoadError"]
    </div>
    return;
}

<div class="mb-4">
    <h2 class="fw-bold" style="color: var(--black-text);">@L["PreferencesTitle"]</h2>
    <p class="text-muted">
        @L["PreferencesIntro"]
        @L["PreferencesMaxHint", Model.MaxPreferences]
    </p>
</div>

<partial name="_StudentAlerts" />

<!-- Student Info Box -->
<div class="alert alert-info d-flex align-items-center mb-4">
    <i class="bi bi-info-circle-fill ms-3" style="font-size: 1.5rem;"></i>
    <div>
        <strong>@L["YourEquivalent"]</strong> <span class="fs-5 fw-bold text-primary">@Model.EquivalentPercentage%</span>
        <span class="mx-2">|</span>
        <strong>@L["YourSection"]</strong> @DisplayHelper.SectionLabel(L, Model.StudentTrack)
    </div>
</div>

<div class="row">
    <!-- Available Colleges -->
    <div class="col-lg-8">
        <div class="card card-university mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-building text-gold ms-2"></i>
                    @L["AvailableColleges"]
                </h5>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
                }

                <div class="row g-3" id="collegesContainer">
                    @foreach (var college in Model.AvailableColleges)
                    {
                        var isEligible = Model.EquivalentPercentage >= college.MinimumScore;
                        var isSelected = Model.SelectedCollegeIds.Contains(college.Id);
                        var displayName = DisplayHelper.CollegeName(college.NameAr, college.NameEn);
                        <div class="col-md-6">
                            <div class="card college-card @(isEligible ? "" : "disabled-college")">
                                <div class="card-body p-3">
                                    <div class="form-check">
                                        <input class="form-check-input college-checkbox"
                                               type="checkbox"
                                               value="@college.Id"
                                               id="college@(college.Id)"
                                               data-college-name="@displayName"
                                               @(!isEligible ? "disabled" : "")
                                               @(isSelected ? "checked" : "")>
                                        <label class="form-check-label fw-bold" for="college@(college.Id)">
                                            @displayName
                                        </label>
                                    </div>
                                    <div class="mt-2">
                                        <small class="text-muted d-block">
                                            <i class="bi bi-arrow-down-circle ms-1"></i>
                                            @L["MinScoreRequired"] <strong class="@(isEligible ? "text-success" : "text-danger")">@college.MinimumScore%</strong>
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Selected Rankings -->
    <div class="col-lg-4">
        <div class="card card-university sticky-top" style="top: 20px;">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-4">
                    <i class="bi bi-list-ol text-gold ms-2"></i>
                    @L["YourSelectedPreferences"]
                </h5>

                <div id="selectedList" class="mb-4">
                    <p class="text-muted text-center py-4" id="emptyMessage">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <br>
                        @L["NoCollegeSelectedYet"]
                    </p>
                </div>

                <form method="post" id="preferencesForm">
                    @Html.AntiForgeryToken()
                    
                    <!-- Container for selected college IDs -->
                    <div id="selectedCollegesHiddenContainer"></div>
                    
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-gold btn-lg" id="submitBtn" disabled>
                            <i class="bi bi-check-circle ms-2"></i>
                            @L["SavePreferences"]
                        </button>
                        <a href="/Student/Dashboard" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-right ms-2"></i>
                            @L["BackShort"]
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script nonce="@Context.Items[ContentSecurityPolicy.NonceItemKey]">
        // Localized strings passed from the server (JSON-encoded so quotes /
        // Arabic / English never break the script).
        const i18n = {
            maxColleges: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["JsMaxColleges"].Value)),
            atLeastOne: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["JsAtLeastOne"].Value)),
            emptyMessage: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["NoCollegeSelectedYet"].Value))
        };

        // Initialize with server-side data (names already localized server-side).
        let selectedColleges = [
            @if (Model.SelectedCollegeIds != null && Model.SelectedCollegeIds.Any())
            {
                foreach (var id in Model.SelectedCollegeIds)
                {
                    var college = Model.AvailableColleges.FirstOrDefault(c => c.Id == id);
                    if (college != null)
                    {
                        var nm = DisplayHelper.CollegeName(college.NameAr, college.NameEn);
                        @Html.Raw($"{{ id: {college.Id}, name: {System.Text.Json.JsonSerializer.Serialize(nm)} }},")
                    }
                }
            }
        ];

        const maxSelections = @Model.MaxPreferences;

        // Handle checkbox changes
        document.querySelectorAll('.college-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                const collegeId = parseInt(this.value);
                const collegeName = this.dataset.collegeName;

                if (this.checked) {
                    if (selectedColleges.length >= maxSelections) {
                        alert(i18n.maxColleges.replace('{0}', maxSelections));
                        this.checked = false;
                        return;
                    }
                    selectedColleges.push({ id: collegeId, name: collegeName });
                } else {
                    selectedColleges = selectedColleges.filter(c => c.id !== collegeId);
                }

                updateSelectedList();
            });
        });

        function updateSelectedList() {
            const listContainer = document.getElementById('selectedList');
            const submitBtn = document.getElementById('submitBtn');
            const hiddenContainer = document.getElementById('selectedCollegesHiddenContainer');

            // Clear previous content
            listContainer.replaceChildren();
            hiddenContainer.replaceChildren();

            if (selectedColleges.length === 0) {
                const message = document.createElement('p');
                message.className = 'text-muted text-center py-4';
                message.id = 'emptyMessage';

                const icon = document.createElement('i');
                icon.className = 'bi bi-inbox fs-2';
                message.append(icon, document.createElement('br'), document.createTextNode(i18n.emptyMessage));
                listContainer.appendChild(message);
                submitBtn.disabled = true;
                return;
            }

            // Build every element through DOM APIs. College names can originate
            // from imported/admin data, so they must never be interpreted as HTML.
            selectedColleges.forEach((college, index) => {
                const item = document.createElement('div');
                item.className = 'preference-item p-3 mb-2 bg-light rounded';

                const row = document.createElement('div');
                row.className = 'd-flex justify-content-between align-items-center';

                const description = document.createElement('div');
                const rank = document.createElement('span');
                rank.className = 'badge bg-gold me-2';
                rank.textContent = String(index + 1);
                const name = document.createElement('strong');
                name.textContent = college.name;
                description.append(rank, name);

                const buttons = document.createElement('div');
                buttons.className = 'btn-group btn-group-sm';
                if (index > 0) {
                    buttons.appendChild(createPreferenceButton('up', index, 'bi-arrow-up'));
                }
                if (index < selectedColleges.length - 1) {
                    buttons.appendChild(createPreferenceButton('down', index, 'bi-arrow-down'));
                }
                buttons.appendChild(createPreferenceButton('remove', college.id, 'bi-x-lg', true));

                row.append(description, buttons);
                item.appendChild(row);
                listContainer.appendChild(item);

                // Create hidden input for each selected college ID
                const hiddenInput = document.createElement('input');
                hiddenInput.type = 'hidden';
                hiddenInput.name = 'SelectedCollegeIds';
                hiddenInput.value = college.id;
                hiddenContainer.appendChild(hiddenInput);
            });

            submitBtn.disabled = false;
        }

        function createPreferenceButton(action, value, iconName, isDanger = false) {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = isDanger ? 'btn btn-outline-danger' : 'btn btn-outline-secondary';
            button.dataset.preferenceAction = action;
            button.dataset.preferenceValue = String(value);

            const icon = document.createElement('i');
            icon.className = `bi ${iconName}`;
            button.appendChild(icon);
            return button;
        }

        function moveUp(index) {
            if (index > 0) {
                [selectedColleges[index], selectedColleges[index - 1]] = [selectedColleges[index - 1], selectedColleges[index]];
                updateSelectedList();
            }
        }

        function moveDown(index) {
            if (index < selectedColleges.length - 1) {
                [selectedColleges[index], selectedColleges[index + 1]] = [selectedColleges[index + 1], selectedColleges[index]];
                updateSelectedList();
            }
        }

        function removeCollege(collegeId) {
            selectedColleges = selectedColleges.filter(c => c.id !== collegeId);

            // Uncheck the checkbox
            const checkbox = document.querySelector(`#college${collegeId}`);
            if (checkbox) checkbox.checked = false;

            updateSelectedList();
        }

        document.getElementById('selectedList').addEventListener('click', function(event) {
            const button = event.target.closest('button[data-preference-action]');
            if (!button || !this.contains(button)) return;

            const value = Number.parseInt(button.dataset.preferenceValue, 10);
            if (!Number.isInteger(value)) return;

            switch (button.dataset.preferenceAction) {
                case 'up':
                    moveUp(value);
                    break;
                case 'down':
                    moveDown(value);
                    break;
                case 'remove':
                    removeCollege(value);
                    break;
            }
        });

        // Handle form submission
        document.getElementById('preferencesForm').addEventListener('submit', function(e) {
            if (selectedColleges.length === 0) {
                e.preventDefault();
                alert(i18n.atLeastOne);
            }
        });

        // Initialize UI on load
        if (selectedColleges.length > 0) {
            updateSelectedList();
        }
    </script>

    <style nonce="@Context.Items[ContentSecurityPolicy.NonceItemKey]">
        .college-card {
            border: 2px solid var(--border-gray);
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .college-card:hover:not(.disabled-college) {
            border-color: var(--primary-gold);
            box-shadow: 0 4px 8px rgba(212, 175, 55, 0.2);
        }

        .disabled-college {
            opacity: 0.6;
            cursor: not-allowed;
        }

        .college-card .form-check-input:checked ~ .form-check-label {
            color: var(--primary-gold);
        }
    </style>
}
