@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = L["ResetPasswordTitle"].Value;
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="card card-university">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold" style="color: var(--black-text);">
                        <i class="bi bi-shield-lock text-gold ms-2"></i>
                        @L["ResetPasswordTitle"]
                    </h3>
                    <p class="text-muted">@L["ResetPasswordSub"]</p>
                </div>

                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    @* Hidden — token and email are never shown to the user. *@
                    <input asp-for="Email" type="hidden" />
                    <input asp-for="Token" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-bold">@L["NewPassword"]</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-lock text-gold"></i>
                            </span>
                            <input asp-for="NewPassword" class="form-control" />
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                        <small class="text-muted">@L["PasswordHint"]</small>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-bold">@L["ConfirmPassword"]</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-lock-fill text-gold"></i>
                            </span>
                            <input asp-for="ConfirmPassword" class="form-control" />
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-gold btn-lg">
                            <i class="bi bi-check-circle ms-2"></i>
                            @L["SetNewPassword"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
