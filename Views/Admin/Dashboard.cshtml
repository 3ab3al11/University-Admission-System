@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@using ANU_Admissions.Helpers
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = L["AdminDashboardTitle"].Value;
}

<div class="mb-4">
    <h2 class="fw-bold" style="color: var(--black-text);">
        <i class="bi bi-shield-lock text-gold ms-2"></i>
        @L["AdminDashboardTitle"]
    </h2>
    <p class="text-muted">@L["AdminDashboardSub"]</p>
</div>

<!-- Statistics Cards -->
<div class="row g-3 mb-4">
    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card card-university h-100">
            <div class="card-body text-center p-3">
                <i class="bi bi-people text-primary" style="font-size: 2rem;"></i>
                <h4 class="mt-2 mb-1 fw-bold">@Model.TotalStudents</h4>
                <small class="text-muted">@L["TotalStudents"]</small>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card card-university h-100">
            <div class="card-body text-center p-3">
                <i class="bi bi-check-circle text-success" style="font-size: 2rem;"></i>
                <h4 class="mt-2 mb-1 fw-bold text-success">@Model.CompletedProfiles</h4>
                <small class="text-muted">@L["CompletedProfile"]</small>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card card-university h-100">
            <div class="card-body text-center p-3">
                <i class="bi bi-list-check text-info" style="font-size: 2rem;"></i>
                <h4 class="mt-2 mb-1 fw-bold text-info">@Model.StudentsWithPreferences</h4>
                <small class="text-muted">@L["ChosePreferences"]</small>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card card-university h-100">
            <div class="card-body text-center p-3">
                <i class="bi bi-trophy text-warning" style="font-size: 2rem;"></i>
                <h4 class="mt-2 mb-1 fw-bold text-warning">@Model.AllocatedCount</h4>
                <small class="text-muted">@L["Allocated"]</small>
            </div>
        </div>
    </div>

    <div class="col-lg-2 col-md-4 col-sm-6">
        <div class="card card-university h-100">
            <div class="card-body text-center p-3">
                <i class="bi bi-hourglass-split text-secondary" style="font-size: 2rem;"></i>
                <h4 class="mt-2 mb-1 fw-bold text-secondary">@Model.PendingAllocation</h4>
                <small class="text-muted">@L["Pending"]</small>
            </div>
        </div>
    </div>

</div>

<!-- Main Action Cards -->
<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="card h-100" style="background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%); border: none;">
            <div class="card-body p-4 text-white">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-play-circle" style="font-size: 3rem; margin-left: 1rem;"></i>
                    <div>
                        <h4 class="mb-1">@L["RunAllocationTitle"]</h4>
                        <p class="mb-0 opacity-75">@L["RunAllocationSub"]</p>
                    </div>
                </div>
                <a href="@Url.Action("RunAllocation")" class="btn btn-light btn-lg">
                    <i class="bi bi-arrow-left-circle ms-2"></i>
                    @L["GoToAllocation"]
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card h-100" style="background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%); border: none;">
            <div class="card-body p-4 text-white">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-gear" style="font-size: 3rem; margin-left: 1rem;"></i>
                    <div>
                        <h4 class="mb-1">@L["SystemControl"]</h4>
                        <p class="mb-0 opacity-75">@L["SystemControlSub"]</p>
                    </div>
                </div>
                <a href="@Url.Action("SystemControl")" class="btn btn-light btn-lg">
                    <i class="bi bi-arrow-left-circle ms-2"></i>
                    @L["GoToSystemControl"]
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-12 mt-3">
        <div class="card h-100" style="background: linear-gradient(135deg, #047857 0%, #10b981 100%); border: none;">
            <div class="card-body p-4 text-white">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-cloud-arrow-up" style="font-size: 3rem; margin-left: 1rem;"></i>
                    <div>
                        <h4 class="mb-1">@L["ImportTitle"]</h4>
                        <p class="mb-0 opacity-75">@L["ImportSub"]</p>
                    </div>
                </div>
                <a href="@Url.Action("ImportOfficialRecords")" class="btn btn-light btn-lg">
                    <i class="bi bi-arrow-left-circle ms-2"></i>
                    @L["ImportPage"]
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Management Navigation -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card card-university h-100">
            <div class="card-body p-3 text-center">
                <i class="bi bi-people text-primary" style="font-size: 2rem;"></i>
                <h6 class="mt-2 mb-1 fw-bold">@L["ManageApplicants"]</h6>
                <small class="text-muted d-block mb-2">@Model.TotalStudents @L["ApplicantUnit"]</small>
                <a href="@Url.Action("Applicants")" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-list ms-1"></i>
                    @L["ShowList"]
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-university h-100">
            <div class="card-body p-3 text-center">
                <i class="bi bi-trophy text-warning" style="font-size: 2rem;"></i>
                <h6 class="mt-2 mb-1 fw-bold">@L["ManageAllocation"]</h6>
                <small class="text-muted d-block mb-2">@Model.AllocatedCount @L["AllocatedUnit"]</small>
                <button class="btn btn-outline-secondary btn-sm w-100" disabled>
                    <i class="bi bi-list ms-1"></i>
                    @L["ComingSoon"]
                </button>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-university h-100">
            <div class="card-body p-3 text-center">
                <i class="bi bi-building text-gold" style="font-size: 2rem;"></i>
                <h6 class="mt-2 mb-1 fw-bold">@L["ManageColleges"]</h6>
                <small class="text-muted d-block mb-2">@Model.TotalColleges @L["CollegeUnit"]</small>
                <a href="@Url.Action("ManageColleges")" class="btn btn-primary btn-sm w-100">
                    <i class="bi bi-gear ms-1"></i>
                    @L["ManageColleges"]
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card card-university h-100">
            <div class="card-body p-3 text-center">
                <i class="bi bi-bar-chart-line text-success" style="font-size: 2rem;"></i>
                <h6 class="mt-2 mb-1 fw-bold">@L["CollegeResults"]</h6>
                <small class="text-muted d-block mb-2">@L["CollegeResultsSub"]</small>
                <a href="@Url.Action("CollegeResultsReport")" class="btn btn-success btn-sm w-100">
                    <i class="bi bi-printer ms-1"></i>
                    @L["OpenReports"]
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Latest Activity Tables -->
<div class="row g-4">
    <!-- Latest Profiles -->
    <div class="col-lg-12">
        <div class="card card-university">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-clock-history text-primary ms-2"></i>
                    @L["LatestApplicants"]
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model.LatestProfiles.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@L["StudentName"]</th>
                                    <th>@L["Email"]</th>
                                    <th>@L["Section"]</th>
                                    <th>@L["EquivalentForAllocation"]</th>
                                    <th>@L["ApplicationDate"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var profile in Model.LatestProfiles)
                                {
                                    <tr>
                                        <td class="fw-bold">@profile.StudentName</td>
                                        <td><small class="text-muted">@profile.Email</small></td>
                                        <td><span class="badge bg-info">@DisplayHelper.SectionLabel(L, profile.Section)</span></td>
                                        <td><strong class="text-gold">@profile.EquivalentPercentage%</strong></td>
                                        <td><small>@profile.ApplicationDate.ToString("dd/MM/yyyy HH:mm")</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">@L["NoApplicantsYet"]</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Latest Allocations -->
    <div class="col-lg-12">
        <div class="card card-university">
            <div class="card-header bg-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-trophy text-warning ms-2"></i>
                    @L["LatestAllocations"]
                </h5>
            </div>
            <div class="card-body p-0">
                @if (Model.LatestAllocations.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-sm mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>@L["Student"]</th>
                                    <th>@L["College"]</th>
                                    <th>@L["Total"]</th>
                                    <th>@L["Date"]</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alloc in Model.LatestAllocations)
                                {
                                    <tr>
                                        <td class="fw-bold">@alloc.StudentName</td>
                                        <td><small>@DisplayHelper.CollegeName(alloc.CollegeName, alloc.CollegeNameEn)</small></td>
                                        <td><span class="badge bg-success">@alloc.StudentScore%</span></td>
                                        <td><small>@alloc.AllocationDate.ToString("dd/MM HH:mm")</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="p-4 text-center text-muted">
                        <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                        <p class="mb-0 mt-2">@L["NotAllocatedYet"]</p>
                    </div>
                }
            </div>
        </div>
    </div>

</div>
