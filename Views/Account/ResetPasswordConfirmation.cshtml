@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@{
    ViewData["Title"] = L["ResetConfirmTitle"].Value;
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-6 col-md-8">
        <div class="card card-university">
            <div class="card-body p-5 text-center">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                <h3 class="fw-bold mt-3" style="color: var(--black-text);">@L["ResetConfirmTitle"]</h3>
                <p class="text-muted mt-3">@L["ResetConfirmBody"]</p>
                <a asp-action="Login" class="btn btn-primary-gold mt-3">
                    <i class="bi bi-box-arrow-in-right ms-2"></i>
                    @L["LoginBtn"]
                </a>
            </div>
        </div>
    </div>
</div>
