@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model int
@{
    var isNotFound = Model == StatusCodes.Status404NotFound;
    ViewData["Title"] = isNotFound
        ? L["PageNotFoundTitle"].Value
        : L["RequestFailedTitle"].Value;
}

<div class="row justify-content-center py-5 text-center">
    <div class="col-lg-7">
        <div class="display-1 fw-bold text-gold">@Model</div>
        <h1 class="h3 fw-bold mt-3">
            @(isNotFound ? L["PageNotFoundTitle"] : L["RequestFailedTitle"])
        </h1>
        <p class="text-muted mb-4">
            @(isNotFound ? L["PageNotFoundBody"] : L["RequestFailedBody"])
        </p>
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary-gold">
            @L["GoHome"]
        </a>
    </div>
</div>
