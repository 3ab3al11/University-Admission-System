@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.LoginViewModel
@{
    ViewData["Title"] = L["LoginTitle"].Value;
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-5 col-md-7">
        <div class="card card-university">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h3 class="fw-bold" style="color: var(--black-text);">
                        <i class="bi bi-box-arrow-in-right text-gold ms-2"></i>
                        @L["LoginTitle"]
                    </h3>
                    <p class="text-muted">@L["LoginWelcome"]</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">@L["Email"]</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-envelope text-gold"></i>
                            </span>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-bold">@L["Password"]</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="bi bi-lock text-gold"></i>
                            </span>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">@L["RememberMe"]</label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-gold fw-bold">@L["ForgotPasswordQ"]</a>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary-gold btn-lg">
                            <i class="bi bi-box-arrow-in-right ms-2"></i>
                            @L["LoginBtn"]
                        </button>
                    </div>
                </form>

                <hr class="my-4">

                <div class="text-center">
                    <p class="mb-0">
                        @L["NoAccountQ"]
                        <a href="/Account/Register" class="text-gold fw-bold">@L["CreateAccountLink"]</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
