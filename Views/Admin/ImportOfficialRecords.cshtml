@using Microsoft.Extensions.Localization
@using ANU_Admissions.Resources
@inject IStringLocalizer<SharedResource> L
@model ANU_Admissions.ViewModels.ImportOfficialRecordsViewModel
@{
    ViewData["Title"] = L["ImportPageTitle"].Value;
    var result = ViewBag.ImportResult as ANU_Admissions.ViewModels.ImportOfficialRecordsResultViewModel;
}

<div class="mb-4">
    <h2 class="fw-bold">
        <i class="bi bi-cloud-arrow-up text-gold ms-2"></i>
        @L["ImportPageTitle"]
    </h2>
    <p class="text-muted">@L["ImportPageSub"]</p>
</div>

<!-- Current stats -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <small class="text-muted">@L["CurrentOfficialRecordsCount"]</small>
                <h4 class="mb-0">@ViewBag.TotalRecords</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <small class="text-muted">@L["EligibleSucceeded"]</small>
                <h4 class="mb-0 text-success">@ViewBag.EligibleRecords</h4>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <small class="text-muted">@L["LastBatch"]</small>
                <h6 class="mb-0">@(ViewBag.LastImportBatch ?? "—")</h6>
                @if (ViewBag.LastImportAt != null)
                {
                    <small class="text-muted">@(((DateTime)ViewBag.LastImportAt).ToString("yyyy-MM-dd HH:mm"))</small>
                }
            </div>
        </div>
    </div>
</div>

@if (result != null)
{
    <!-- Import Result Panel -->
    @if (result.Aborted)
    {
        <div class="alert alert-danger">
            <h5 class="alert-heading">
                <i class="bi bi-x-octagon-fill ms-2"></i>
                @L["ImportAborted"]
            </h5>
            <p class="mb-1">@result.AbortReason</p>
            <hr />
            <small>@L["ElapsedTime"]: @result.Duration.TotalSeconds.ToString("F2") @L["TimeLabel"].</small>
        </div>
    }
    else
    {
        <div class="alert alert-success">
            <h5 class="alert-heading">
                <i class="bi bi-check-circle-fill ms-2"></i>
                @L["ImportSucceeded"]
            </h5>
            <p class="mb-0">
                @L["BatchLabel"]: <strong>@result.ImportBatch</strong> ·
                @L["MaxScoreLabel"]: <strong>@result.MaxScoreUsed</strong> ·
                @L["TimeLabel"]: <strong>@result.Duration.TotalSeconds.ToString("F2")</strong>
            </p>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-2"><div class="card text-center"><div class="card-body"><small class="text-muted">@L["RowsRead"]</small><h4 class="mb-0">@result.TotalRowsRead</h4></div></div></div>
        <div class="col-md-2"><div class="card text-center bg-success bg-opacity-10"><div class="card-body"><small class="text-muted">@L["EligibleShort"]</small><h4 class="mb-0 text-success">@result.Imported</h4></div></div></div>
        <div class="col-md-2"><div class="card text-center bg-warning bg-opacity-10"><div class="card-body"><small class="text-muted">@L["NotEligible"]</small><h4 class="mb-0 text-warning">@result.NotEligibleImported</h4></div></div></div>
        <div class="col-md-2"><div class="card text-center bg-danger bg-opacity-10"><div class="card-body"><small class="text-muted">&gt; 100%</small><h4 class="mb-0 text-danger">@result.SkippedOverMaxScore</h4></div></div></div>
        <div class="col-md-2"><div class="card text-center"><div class="card-body"><small class="text-muted">@L["MissingData"]</small><h4 class="mb-0">@result.SkippedMissingData</h4></div></div></div>
        <div class="col-md-2"><div class="card text-center"><div class="card-body"><small class="text-muted">@L["Duplicate"]</small><h4 class="mb-0">@(result.SkippedDuplicateInFile + result.SkippedAlreadyInDb)</h4></div></div></div>
    </div>

    @if (result.FirstErrors.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-light">
                <strong>@L["FirstProblemRows"] (@result.FirstErrors.Count)</strong>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>@L["RowNumber"]</th>
                            <th>@L["SeatNumber"]</th>
                            <th>@L["Reason"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var err in result.FirstErrors)
                        {
                            <tr>
                                <td>@err.RowNumber</td>
                                <td>@err.SeatNumber</td>
                                <td>@err.Reason</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<!-- Upload Form -->
@if (ViewBag.HasRecords == true)
{
    <div class="card shadow-sm border-warning">
        <div class="card-body">
            <div class="alert alert-warning mb-3">
                <i class="bi bi-exclamation-triangle-fill ms-2"></i>
                @L["ImportFileExists"]
            </div>
            <ul class="list-unstyled mb-0">
                <li><strong>@L["CurrentRecordsLabel"]:</strong> @ViewBag.TotalRecords</li>
                <li><strong>@L["CurrentBatchLabel"]:</strong> @(ViewBag.LastImportBatch ?? "—")</li>
                @if (ViewBag.LastImportAt != null)
                {
                    <li><strong>@L["LastImportDate"]:</strong> @(((DateTime)ViewBag.LastImportAt).ToString("yyyy-MM-dd HH:mm"))</li>
                }
            </ul>
            <div class="mt-3 d-flex gap-2">
                <a asp-action="DeleteOfficialRecords" class="btn btn-danger">
                    <i class="bi bi-trash ms-2"></i>
                    @L["DeleteCurrentOfficial"]
                </a>
                <a asp-action="Dashboard" class="btn btn-outline-secondary">@L["BackToDashboard"]</a>
            </div>
        </div>
    </div>
}
else
{
<div class="card shadow-sm">
    <div class="card-header bg-light">
        <strong>@L["UploadNewFile"]</strong>
    </div>
    <div class="card-body">
        <form asp-action="ImportOfficialRecords" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="ExcelFile" class="form-label fw-bold"></label>
                <input asp-for="ExcelFile" type="file" class="form-control" accept=".xlsx,.xls" required />
                <span asp-validation-for="ExcelFile" class="text-danger"></span>
                <small class="text-muted">@L["ExcelFileHint"]</small>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="MaxScore" class="form-label fw-bold"></label>
                    <input asp-for="MaxScore" type="number" step="0.01" class="form-control" required />
                    <span asp-validation-for="MaxScore" class="text-danger"></span>
                    <small class="text-muted">@L["MaxScoreHint"]</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="ImportBatch" class="form-label fw-bold"></label>
                    <input asp-for="ImportBatch" class="form-control" placeholder="@L["ImportBatchPlaceholder"]" />
                    <small class="text-muted">@L["ImportBatchHint"]</small>
                </div>
            </div>

            <div class="form-check mb-3">
                <input asp-for="AbortOnAnyOverflow" class="form-check-input" />
                <label asp-for="AbortOnAnyOverflow" class="form-check-label"></label>
                <div><small class="text-muted">@L["AbortOnOverflowHint"]</small></div>
            </div>

            <div class="alert alert-warning small">
                <i class="bi bi-exclamation-triangle ms-1"></i>
                @L["ServerComputesHint"]
            </div>

            <button type="submit" class="btn btn-primary-gold">
                <i class="bi bi-upload ms-2"></i> @L["StartImport"]
            </button>
            <a asp-action="Dashboard" class="btn btn-outline-secondary">@L["BackShort"]</a>
        </form>
    </div>
</div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
