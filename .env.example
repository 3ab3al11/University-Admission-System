# Copy this file to .env and choose a strong local-only SQL Server password.
# SQL Server requires at least 8 characters from 3 of: upper, lower, digits, symbols.
MSSQL_SA_PASSWORD=

# Optional host ports and public URL.
MSSQL_PORT=14333
APP_PORT=8080
PUBLIC_BASE_URL=http://localhost:8080

# Optional initial admin. Leave blank to skip admin creation safely.
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=
ADMIN_SEED_FULL_NAME=System Administrator
